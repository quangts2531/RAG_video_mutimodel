# ── Version Control ──────────────────────────────────────────────
.git
.gitignore

# ── IDE / Editor ─────────────────────────────────────────────────
.idea
.vscode
*.swp
*.swo

# ── Python bytecode & caches ─────────────────────────────────────
__pycache__
*.pyc
*.pyo
.pytest_cache

# ── Virtual environments ─────────────────────────────────────────
venv
.venv
env

# ── Environment & secrets ────────────────────────────────────────
.env

# ── Database files (created at runtime, not baked into image) ────
*.db

# ── Large data directories (mounted as volumes instead) ──────────
dataset/
frame/
cache/

# ── Offline pipeline tools (not part of the API runtime) ─────────
video_encoder.py
ollama_modal.py

# ── JSON data (mounted as volumes, not baked into image) ─────────
document.json
result_document.json

# ── Docker files themselves ──────────────────────────────────────
Dockerfile
docker-compose.yaml
docker-compose*.yaml

# ── Documentation ────────────────────────────────────────────────
*.md
LICENSE
